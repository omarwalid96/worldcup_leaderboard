# ─────────────────────────────────────────────────────────────
# GroupStage — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — used by cron/grading + admin seeding. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Supabase → Project Settings → Database → Connection string → "URI") ---
# Use the connection pooler (port 6543) URI for serverless. Drizzle migrations can use either.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-region.pooler.supabase.com:6543/postgres

# --- Football data provider (no API key needed) ---
# "worldcup26"   → worldcup26.ir near-live + openfootball fallback (default)
# "worldcup26only" → worldcup26.ir only
# "openfootball" → fixtures + final results only (most reliable, no in-play)
FOOTBALL_PROVIDER=worldcup26

# --- Web Push (generate with: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Cron security ---
# Random secret; Vercel Cron sends it as a Bearer token so only the cron can hit the endpoints.
CRON_SECRET=change-me-to-a-long-random-string

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
